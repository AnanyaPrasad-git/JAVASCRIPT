<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ananya Prasad - SIT Nagpur</title>
    
    <!-- INTERNAL CSS: Centers content, styles cards, and sets unique row colors -->
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background-color: #f0f2f5;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .container {
            background: #ffffff;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            text-align: center;
            max-width: 600px;
            width: 90%;
        }
        .info-line {
            font-size: 1.25rem;
            font-weight: 600;
            margin: 15px 0;
            padding: 12px;
            border-radius: 8px;
            opacity: 0;
            transform: translateY(20px);
            animation: fadeInUp 0.6s forwards;
        }
        /* Unique colors for each line as requested */
        .line-1 { color: #ffffff; background-color: #4a90e2; animation-delay: 0.2s; }
        .line-2 { color: #ffffff; background-color: #2ecc71; animation-delay: 0.4s; }
        .line-3 { color: #ffffff; background-color: #9b59b6; animation-delay: 0.6s; }
        .line-4 { color: #ffffff; background-color: #e67e22; animation-delay: 0.8s; }
        
        .btn-container {
            margin-top: 25px;
        }
        button {
            padding: 10px 20px;
            font-size: 1rem;
            font-weight: bold;
            color: #fff;
            background-color: #34495e;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            transition: background 0.3s;
        }
        button:hover {
            background-color: #2c3e50;
        }
        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>

    <!-- INTERNAL JAVASCRIPT: Demonstrates console methods and internal logic -->
    <script>
        // Console methods demo
        console.log("Internal JS: Page loading sequence started.");
        console.info("User Info: Ananya Prasad | Sem V | BTech CSE");
        console.warn("Demo Warning: This webpage uses combined JS methodologies.");

        function showInternalAlert() {
            alert("Hello Ananya! This alert is triggered by Internal JavaScript.");
            console.log("Console Log: Internal JS button clicked.");
        }
    </script>
</head>
<body>

    <!-- MAIN CARD: Perfectly centered on the screen -->
    <div class="container">
        
        <!-- INLINE CSS: Demostrating inline styles with specific unique colors per line -->
        <div class="info-line line-1" style="border: 2px solid #2980b9;">
            Welcome to SIT Nagpur
        </div>
        
        <div class="info-line line-2" style="border: 2px solid #27ae60;">
            Name: Ananya Prasad
        </div>
        
        <div class="info-line line-3" style="border: 2px solid #8e44ad;">
            Semester: Sem V | Branch: BTech CSE
        </div>
        
        <div class="info-line line-4" style="border: 2px solid #d35400;">
            Welcome to Inline CSS and JavaScript Programming
        </div>

        <!-- JAVASCRIPT ACTIONS -->
        <div class="btn-container">
            <!-- INLINE JAVASCRIPT: Executed directly within the onclick attribute -->
            <button onclick="console.log('Console Log: Inline JS button clicked.'); alert('Welcome! This is an Inline JavaScript alert.');" style="margin-right: 10px;">
                Inline JS Alert
            </button>

            <!-- INTERNAL JAVASCRIPT CALL -->
            <button onclick="showInternalAlert();" style="margin-right: 10px;">
                Internal JS Alert
            </button>

            <!-- EXTERNAL JAVASCRIPT CALL -->
            <button onclick="showExternalAlert();">
                External JS Alert
            </button>
        </div>

    </div>

    <!-- EXTERNAL JAVASCRIPT EMBED -->
    <!-- Note: In a real project, replace this Data URI with an actual file path like src="script.js" -->
    <script src="data:text/javascript,
        console.log('External JS: Script successfully loaded via Data URI.');
        function showExternalAlert() {
            alert('Greetings Ananya! This message comes from External JavaScript.');
            console.dir(document.body);
        }
    "></script>

</body>
</html>
