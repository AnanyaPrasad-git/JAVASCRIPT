<!DOCTYPE html>
<html>
    <head>
        <title>Billing Calculator</title>
    </head>
    <body>
        <h3>Name: Ananya Prasad</h3>
        <h2>PRN no.: 24070521141</h2>
        <h3>Name: Ananya Prasad</h3>
        <h2>PRN no.: 24070521141</h2>
        <h2>Billing Calculator</h2>

        <form id="billForm" style="margin:12px 0;">
            <label>Customer name: <input name="customer" required></label><br />
            <label>PRN: <input name="prn" required></label><br />
            <label>Product: <input name="product" required></label><br />
            <label>Quantity: <input name="quantity" type="number" min="0" required></label><br />
            <label>Price per item: <input name="price" type="number" step="0.01" min="0" required></label><br />
            <button type="submit">Calculate</button>
        </form>

        <div id="receipt" style="margin-top:18px;"></div>

        <script>
            // Demonstration: var, let, const; template literals; object & array destructuring
            const GST = 0.18; // constant

            // legacy variable using var
            var legacyNote = 'legacy var example';

            const form = document.getElementById('billForm');
            const receipt = document.getElementById('receipt');

            form.addEventListener('submit', function (e) {
                e.preventDefault();

                // Use FormData to read inputs
                let fd = new FormData(form);
                // Build an input object (let used for mutable container)
                let input = {
                    customer: (fd.get('customer') || '').toString().trim(),
                    prn: (fd.get('prn') || '').toString().trim(),
                    product: (fd.get('product') || '').toString().trim(),
                    quantity: Number(fd.get('quantity')),
                    price: Number(fd.get('price'))
                };

                if (Number.isNaN(input.quantity) || input.quantity < 0) input.quantity = 0;
                if (Number.isNaN(input.price) || input.price < 0) input.price = 0;

                // Derived values
                let total = input.quantity * input.price;
                let gstAmount = total * GST;
                let finalBill = total + gstAmount;

                // Immutable bill object
                const bill = { ...input, total, gstAmount, finalBill };

                // Object destructuring
                const { customer, prn, product, quantity, price, total: subtotal, gstAmount: gstAmt, finalBill: amount } = bill;

                // Array destructuring example
                const [sub, gstV, finalV] = [subtotal, gstAmt, amount];

                // Render using template literals
                receipt.innerHTML = `
                    <h3>Billing receipt:</h3>
                    <p><strong>Customer:</strong> ${customer}</p>
                    <p><strong>Product:</strong> ${product}</p>
                    <p><strong>PRN:</strong> ${prn}</p>
                    <p><strong>Quantity:</strong> ${quantity}</p>
                    <p><strong>Price per item:</strong> ₹${price.toFixed(2)}</p>
                    <p><strong>Total:</strong> ₹${sub.toFixed(2)}</p>
                    <p><strong>GST Amount (18%):</strong> ₹${gstV.toFixed(2)}</p>
                    <h3>Final Bill: ₹${finalV.toFixed(2)}</h3>
                    <hr />
                    <p><em>Notes:</em> var used: ${legacyNote}; demonstrates `let`, `const`, template literals, object & array destructuring.</p>
                `;
            });
        </script>
